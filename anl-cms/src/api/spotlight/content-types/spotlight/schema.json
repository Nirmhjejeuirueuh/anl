{
  "kind": "collectionType",
  "collectionName": "spotlights",
  "info": {
    "singularName": "spotlight",
    "pluralName": "spotlights",
    "displayName": "Spotlight"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "mediaType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "direct video",
        "youtube video",
        "image"
      ]
    },
    "image": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "mediaType"
            },
            "image"
          ]
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "video": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "mediaType"
            },
            "direct video"
          ]
        }
      },
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "videos"
      ]
    },
    "thumbnail": {
      "type": "media",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "mediaType"
            },
            "direct video"
          ]
        }
      },
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "videoUrl": {
      "type": "string",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "mediaType"
            },
            "youtube video"
          ]
        }
      },
      "required": false
    }
  }
}
