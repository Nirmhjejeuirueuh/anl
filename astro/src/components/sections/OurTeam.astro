---
import { getAllTeamMembers } from "@/lib/strapiApi";
import TeamCard from "@/layouts/components/cards/TeamCard.astro";

const teamMembers = await getAllTeamMembers();

// Sort by order to ensure CEO comes first
const sortedTeam = teamMembers?.sort((a: any, b: any) => a.order - b.order) || [];

// Separate CEO from rest of team
const ceo = sortedTeam.find((member: any) => member.order === 1);
const otherMembers = sortedTeam.filter((member: any) => member.order !== 1);
---

<section class="py-16 md:py-20 lg:py-24 bg-gradient-to-br from-primary/5 via-transparent to-primary/5">
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <h2 class="text-h2 mb-6 text-primary">Meet The Team</h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        Our diverse team of experts brings together deep industry knowledge, innovative thinking, and a passion for excellence.
      </p>
    </div>

    {sortedTeam && sortedTeam.length > 0 ? (
      <div class="grid lg:grid-cols-12 items-center justify-center max-w-7xl mx-auto">
        <!-- CEO Featured Section - Left Side -->
        {ceo && (
          <div class="mx-6 lg:col-span-4 max-w-md mt-8" data-aos="fade-right">
            <a href={`/about/team/${ceo.slug}`} class="block group hover:no-underline relative z-10">
              <div class="bg-gradient-to-br from-primary to-primary/80 p-8 text-white shadow-2xl rounded-2xl transition-all duration-300 group-hover:shadow-2xl group-hover:scale-105 min-h-[600px] flex flex-col justify-center">
                <!-- Large CEO Profile -->
                <div class="flex flex-col items-center text-center">
                  <div class="w-48 h-48 rounded-full overflow-hidden border-4 border-white shadow-xl mb-12 group-hover:scale-105 transition-all duration-300">
                    {ceo.image ? (
                      <img 
                        src={ceo.image} 
                        alt={ceo.name}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <div class="w-full h-full bg-white/20 flex items-center justify-center">
                        <span class="text-6xl text-white">{ceo.name?.charAt(0)}</span>
                      </div>
                    )}
                  </div>
                  
                  <h3 class="text-2xl font-bold mb-4 text-white">{ceo.name}</h3>
                  <p class="text-2xl opacity-90 mb-6 text-white">{ceo.role}</p>
                  
                  {ceo.description && (
                    <p class="text-sm opacity-90 leading-relaxed max-w-md text-white mb-8">
                      {ceo.description}
                    </p>
                  )}
                </div>
              </div>
            </a>
          </div>
        )}

        <!-- Rest of the Team - Right Side -->
        <div class="lg:col-span-8" data-aos="fade-left">
          {otherMembers && otherMembers.length > 0 && (
            <>
              <p class="text-sm text-muted/70 italic mb-4 text-center">Click on a profile to view full bio</p>
              <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
              {otherMembers.map((member: any, index: number) => (
                <a
                  href={`/about/team/${member.slug}`}
                  data-aos="fade-up"
                  data-aos-delay={100 + index * 50}
                  class="group block hover:no-underline"
                >
                  <div class="bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition-all duration-300 border border-gray-100 h-full flex flex-col items-center text-center group-hover:scale-105">
                    <!-- Circular Profile Image -->
                    <div class="w-36 h-36 mx-auto mb-4 rounded-full overflow-hidden border-4 border-primary/20 shadow-lg group-hover:border-primary/40 transition-all group-hover:scale-105">
                      {member.image ? (
                        <img 
                          src={member.image} 
                          alt={member.name}
                          class="w-full h-full object-cover"
                        />
                      ) : (
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center">
                          <span class="text-4xl text-gray-400">{member.name?.charAt(0)}</span>
                        </div>
                      )}
                    </div>
                    
                    <h4 class="font-semibold text-lg text-gray-900 mb-1">{member.name}</h4>
                    <p class="text-sm text-primary font-medium">{member.role}</p>
                    
                    {member.description && (
                      <p class="text-xs text-gray-600 mt-2 line-clamp-2">
                        {member.description}
                      </p>
                    )}
                  </div>
                </a>
              ))}
            </div>
            </>
          )}
        </div>
      </div>
    ) : (
      <div class="text-center py-12" data-aos="fade-up">
        <div class="bg-gray-100 rounded-lg p-8 max-w-md mx-auto">
          <h3 class="text-lg font-semibold text-gray-800 mb-2">Team Section</h3>
          <p class="text-gray-600">Team members will be displayed here once added to the CMS.</p>
          <p class="text-sm text-gray-500 mt-2">API returned {sortedTeam?.length || 0} members</p>
        </div>
      </div>
    )}
  </div>
</section>
