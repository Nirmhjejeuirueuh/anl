---
/**
 * Reusable marquee carousel for media library sections.
 * Pass `sections` (raw from Strapi) and optionally `showBadge` to display
 * a "Past Highlight" label on each section header.
 */
import { STRAPI_URL } from "@/lib/utils/strapiApi";
import { processItems, sortItemsByDate, getItemCaption, getFullItemCaption } from "@/lib/utils/mediaLibraryUtils";

interface Props {
  sections: any[];
  showBadge?: boolean;
}

const { sections, showBadge = false } = Astro.props;
---

<section class="py-8 bg-gray-50">
  <div class="space-y-12">
    {sections.map((section) => {
      const rawItems = section.media || section.photos || [];
      const displayItems = sortItemsByDate(processItems(rawItems));
      if (!displayItems.length) return null;
      const sectionId = `section-row-${section.id}`;

      return (
        <div id={`section-anchor-${section.id}`} class="section-row">
          {/* Section Header */}
          <div class="container mb-4 text-center">
            <div class="inline-flex flex-col items-center gap-2">
              <div class="flex items-center gap-3">
                {showBadge && (
                  <span class="text-xs font-semibold uppercase tracking-widest text-gray-400 bg-gray-200 px-2 py-1 rounded">
                    Past Highlight
                  </span>
                )}
                <h2 class="text-2xl lg:text-3xl font-bold text-gray-900">
                  {section.title}
                  <span class="ml-2 text-lg font-normal text-gray-400">({displayItems.length})</span>
                </h2>
              </div>
              {section.description && (
                <p class="text-gray-500 text-sm max-w-xl">{section.description}</p>
              )}
            </div>
          </div>

          {/* Marquee Row */}
          <div class="relative overflow-hidden group/row">
            <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-gray-50 to-transparent z-10"></div>
            <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-gray-50 to-transparent z-10"></div>

            <div id={sectionId} class="marquee-track flex gap-4 pb-3">
              {displayItems.map((item, itemIndex) => {
                const isImage = item.mime?.startsWith('image');
                const isVideo = item.mime?.startsWith('video');
                const isAudio = item.mime?.startsWith('audio');
                const itemUrl = item.url.startsWith('http') ? item.url : `${STRAPI_URL}${item.url}`;

                const coverArt   = item._coverArt;
                const thumbnail  = item._thumbnail;
                const thumbnailUrl = thumbnail  ? (thumbnail.url.startsWith('http')  ? thumbnail.url  : `${STRAPI_URL}${thumbnail.url}`)  : '';
                const coverUrl     = coverArt   ? (coverArt.url.startsWith('http')   ? coverArt.url   : `${STRAPI_URL}${coverArt.url}`)   : '';

                const cardCaption = getItemCaption(item, itemIndex);
                const cardAlt     = item.alternativeText || cardCaption;

                const onclickArgs = `'${itemUrl.replace(/'/g, "\\'")}', '${getFullItemCaption(item, itemIndex).replace(/'/g, "\\'")}', '${cardAlt.replace(/'/g, "\\'")}', '${getFullItemCaption(item, itemIndex).replace(/'/g, "\\'")}', ${JSON.stringify(displayItems).replace(/'/g, "\\'")}, ${itemIndex}`;

                return (
                  <div
                    class="group/card flex-shrink-0 w-[560px] bg-white rounded-xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden cursor-pointer"
                    onclick={`openMediaModal(${onclickArgs})`}
                  >
                    <div class="aspect-[16/9] overflow-hidden relative">
                      {isImage && (
                        <img src={itemUrl} alt={cardAlt} loading="lazy"
                          class="w-full h-full object-cover object-top group-hover/card:scale-105 transition-transform duration-300" />
                      )}
                      {isVideo && thumbnailUrl && (
                        <img src={thumbnailUrl} alt={cardAlt} loading="lazy"
                          class="w-full h-full object-cover object-top group-hover/card:scale-105 transition-transform duration-300" />
                      )}
                      {isVideo && !thumbnailUrl && (
                        <video src={itemUrl} preload="metadata" muted
                          class="w-full h-full object-cover" style="pointer-events:none" />
                      )}
                      {isAudio && coverUrl && (
                        <img src={coverUrl} alt={cardAlt} loading="lazy"
                          class="w-full h-full object-cover object-top group-hover/card:scale-105 transition-transform duration-300" />
                      )}
                      {isAudio && !coverUrl && (
                        <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
                          </svg>
                        </div>
                      )}
                      {isVideo && (
                        <span class="absolute top-2 left-2 bg-black/60 text-white text-xs px-2 py-0.5 rounded-full flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                          Video
                        </span>
                      )}
                      {isAudio && (
                        <span class="absolute top-2 left-2 bg-black/60 text-white text-xs px-2 py-0.5 rounded-full flex items-center gap-1">
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
                          </svg>
                          Audio
                        </span>
                      )}
                    </div>
                    <div class="px-4 py-3">
                      <p class="font-medium text-gray-800 text-sm truncate text-center">{cardCaption}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: marquee-scroll linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>

<script define:vars={{ STRAPI_URL }}>
  document.addEventListener('DOMContentLoaded', function () {
    window.STRAPI_URL = STRAPI_URL;

    document.querySelectorAll('.marquee-track').forEach(track => {
      const originals = Array.from(track.children);
      originals.forEach(child => {
        const clone = child.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      });
      const totalWidth = track.scrollWidth / 2;
      const duration = Math.max(8, totalWidth / 120);
      track.style.animationDuration = `${duration}s`;
    });
  });
</script>
