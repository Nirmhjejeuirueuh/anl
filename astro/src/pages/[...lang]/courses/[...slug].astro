---
import Base from "@/layouts/Base.astro";
import { getCourses, getFtsCourseDetail, convertStrapiCourseToAstro, STRAPI_URL } from "@/lib/utils/strapiApi";
import CallToAction from "@/components/sections/CallToAction.astro";
import config from ".astro/config.generated.json" assert { type: "json" };
import { markdownify, pluralize } from "@/lib/utils/textConverter";
import OptimizedImage from "@/layouts/components/utilities/OptimizedImage.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import type { StrapiCourse } from "@/lib/utils/strapiApi";

export async function getStaticPaths() {
  const courses = await getCourses();
  return generatePaths().flatMap(({ params: { lang } }) =>
    courses.map(course => ({ params: { lang, slug: course.slug }, props: { strapiCourse: course } }))
  );
}

const { lang, slug } = Astro.params;
const { strapiCourse } = Astro.props as { strapiCourse: StrapiCourse };

// Handle missing slug parameter
if (!slug) {
  console.log('No slug provided, redirecting to 404');
  return Astro.redirect('/404');
}

// Handle 404 if course not found (should not happen at build time)
if (!strapiCourse) {
  console.log('No course found, redirecting to 404');
  return Astro.redirect('/404');
}

// Convert Strapi course to Astro format
const course = convertStrapiCourseToAstro(strapiCourse);

// Fetch FTS detail if this is an FTS programme
const isFts = course.data.ftsProgramme;
const ftsDetail = isFts ? await getFtsCourseDetail() : null;

const ftsEligibilityHtml = ftsDetail?.eligibilty ? markdownify(ftsDetail.eligibilty, true) : '';
const ftsCourseFees = ftsDetail?.courseFees ? markdownify(ftsDetail.courseFees, true) : '';

// Additional course details
const tags = course.data.tags || [];

console.log('COURSE ROUTE: About to render course:', course.data.title);
---

<Base
  title={course.data.title}
  description={course.data.description}
  image={undefined}
>
  <section class="py-12">
    <div class="container">
      
      <!-- Back Navigation -->
      <div class="mb-8">
        <a
          href={`${lang ? `/${lang}` : ''}/courses`}
          class="inline-flex items-center gap-2 text-gray-600 hover:text-primary transition-colors duration-200 group"
          aria-label="Back to courses list"
        >
          <svg 
            class="w-5 h-5 transition-transform duration-200 group-hover:-translate-x-1" 
            fill="none" 
            stroke="currentColor" 
            viewBox="0 0 24 24"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            />
          </svg>
          <span class="font-medium">Back to Courses</span>
        </a>
      </div>
      
      <div class="grid grid-cols-1 justify-items-center space-y-12">
        <!-- Course Meta -->
        <div class="max-w-full space-y-8 text-center lg:max-w-3xl">
          <div>
            <h1 class="text-h3 md:text-h2">{course.data.title}</h1>
            {tags && tags.length > 0 && (
              <div class="flex justify-center flex-wrap gap-2 mt-2 mb-2">
                {tags.map((tag, i) => (
                  <span class={`text-xs px-2 py-1 rounded ${['bg-red-100 text-red-800','bg-yellow-100 text-yellow-800','bg-green-100 text-green-800','bg-cyan-100 text-cyan-800','bg-blue-100 text-blue-800'][i % 5]}`}>
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Course Info Row -->
            <div class="mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
              <div class="flex flex-wrap justify-center items-center gap-4 text-sm text-muted">
                {course.data.moduleCode && <span>{course.data.moduleCode}</span>}
                {course.data.moduleCode && (course.data.courseFamily || course.data.trainingDays) && <span class="text-gray-400">|</span>}
                {course.data.courseFamily && <span>{course.data.courseFamily}</span>}
                {(course.data.moduleCode || course.data.courseFamily) && course.data.trainingDays && <span class="text-gray-400">|</span>}
                {course.data.trainingDays && <span>{course.data.trainingDays} {pluralize(course.data.trainingDays, 'day')}</span>}
              </div>
            </div>
          </div>
        </div>

        <!-- Course Details -->
        <div class="w-full max-w-full lg:max-w-4xl">
          {isFts ? (
            <!-- FTS Programme: Tabbed layout -->
            <div class="fts-tabs">
              <!-- Tab buttons -->
              <div class="flex flex-wrap gap-2 mb-8" role="tablist">
                {['Overview', 'Eligibility & Terms', 'Course Fees'].map((label, i) => (
                  <button
                    class="fts-tab-btn px-5 py-2 rounded-full text-sm font-semibold transition-all duration-200"
                    data-tab={i}
                    role="tab"
                  >
                    {label}
                  </button>
                ))}
              </div>

              <!-- Tab panels -->
              <div class="fts-tab-panel space-y-12" data-panel="0">
                {course.data.description && (
                  <div class="space-y-4">
                    <h2 class="text-2xl font-bold">Overview</h2>
                    <div class="prose-styles" set:html={markdownify(course.data.description, true)}></div>
                  </div>
                )}
                {course.data.learningObjectives && (
                  <div class="space-y-4">
                    <h2 class="text-2xl font-bold">Learning Objectives</h2>
                    <div class="prose-styles" set:html={markdownify(course.data.learningObjectives, true)}></div>
                  </div>
                )}
                {course.data.targetAudience && (
                  <div class="space-y-4">
                    <h2 class="text-2xl font-bold">Target Audience</h2>
                    <div class="prose-styles" set:html={markdownify(course.data.targetAudience, true)}></div>
                  </div>
                )}
                {course.data.schedule && (
                  <div class="space-y-4">
                    <h2 class="text-2xl font-bold">Schedule</h2>
                    <span class="text-text-default">{course.data.schedule}</span>
                  </div>
                )}
                {course.data.hyperlink && (
                  <div class="space-y-4">
                    <h2 class="text-2xl font-bold">Brochure</h2>
                    <a
                      href={course.data.hyperlink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-lg font-medium"
                    >
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                      View Course Brochure
                    </a>
                  </div>
                )}
              </div>

              <div class="fts-tab-panel hidden" data-panel="1">
                <div class="prose-styles" set:html={ftsEligibilityHtml} />
              </div>

              <div class="fts-tab-panel hidden" data-panel="2">
                <div class="prose-styles" set:html={ftsCourseFees} />
              </div>
            </div>
          ) : (
            <!-- Non-FTS: flat layout -->
            <div class="space-y-12">
              {course.data.description && (
                <div class="space-y-4">
                  <h2 class="text-2xl font-bold">Overview</h2>
                  <div class="prose-styles" set:html={markdownify(course.data.description, true)}></div>
                </div>
              )}
              {course.data.learningObjectives && (
                <div class="space-y-4">
                  <h2 class="text-2xl font-bold">Learning Objectives</h2>
                  <div class="prose-styles" set:html={markdownify(course.data.learningObjectives, true)}></div>
                </div>
              )}
              {course.data.targetAudience && (
                <div class="space-y-4">
                  <h2 class="text-2xl font-bold">Target Audience</h2>
                  <div class="prose-styles" set:html={markdownify(course.data.targetAudience, true)}></div>
                </div>
              )}
              {course.data.schedule && (
                <div class="space-y-4">
                  <h2 class="text-2xl font-bold">Schedule</h2>
                  <span class="text-text-default">{course.data.schedule}</span>
                </div>
              )}
              {course.data.hyperlink && (
                <div class="space-y-4">
                  <h2 class="text-2xl font-bold">Brochure</h2>
                  <a
                    href={course.data.hyperlink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors text-lg font-medium"
                  >
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    View Course Brochure
                  </a>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <CallToAction />
</Base>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.fts-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.fts-tab-panel');

  function activateTab(index: number) {
    tabs.forEach((btn, i) => {
      const active = i === index;
      btn.classList.toggle('bg-[#00025d]', active);
      btn.classList.toggle('text-white', active);
      btn.classList.toggle('shadow-sm', active);
      btn.classList.toggle('bg-gray-100', !active);
      btn.classList.toggle('text-gray-600', !active);
      btn.classList.toggle('hover:bg-gray-200', !active);
    });
    panels.forEach((panel, i) => {
      panel.classList.toggle('hidden', i !== index);
    });
  }

  tabs.forEach((btn, i) => {
    btn.addEventListener('click', () => activateTab(i));
  });

  if (tabs.length) activateTab(0);

  // Open all content links in a new tab
  document.querySelectorAll<HTMLAnchorElement>('.fts-tab-panel a, .space-y-12 a').forEach(a => {
    a.target = '_blank';
    a.rel = 'noopener noreferrer';
  });
</script>
