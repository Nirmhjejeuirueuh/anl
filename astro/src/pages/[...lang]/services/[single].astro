---
import Base from "@/layouts/Base.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import { getServicesPage, STRAPI_URL } from "@/lib/utils/strapiApi";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import { markdownify } from "@/lib/utils/textConverter";

export async function getStaticPaths() {
  // Uses getServicesPage() which is cached — avoids the broken
  // ?populate[services][fields]=endpoint query that returns 400 in Strapi v5
  const pageData = await getServicesPage();
  const services: any[] = pageData?.services || [];
  return generatePaths().flatMap(({ params: { lang } }) =>
    services.filter((s: any) => s.endpoint).map((s: any) => ({
      params: { lang, single: s.endpoint.replace(/^\//, '') }
    }))
  );
}

const { single: endpoint } = Astro.params as any;

// Fetch services page to get the service data (cached — no extra HTTP request)
const pageData = await getServicesPage();

// Find the service that matches the endpoint
const service = pageData?.services?.find((s: any) => 
  s.endpoint === endpoint || s.endpoint === `/${endpoint}`
);

if (!service) {
  throw new Error(`Service with endpoint "${endpoint}" not found`);
}
---

<Base title={service.title} fitToScreen={false}>
  <PageHeader title={service.title} />

  <!-- Service Hero Section -->
  <section class="relative py-16 md:py-20 lg:py-24 -mt-16">
    <div class="container">
      <div class="mx-auto max-w-4xl">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
          <!-- Content -->
          <div data-aos="fade-up-sm">
            <h1 class="text-h2 md:text-h1 text-primary mb-6">{service.title}</h1>
            <div class="text-gray-600 leading-relaxed space-y-4 mb-12 text-left">
              <div set:html={markdownify(service.description, true)}></div>
            </div>
          </div>

          <!-- Image -->
          {service.image && (
            <div data-aos="fade-up-sm" data-aos-delay="200" class="relative">
              <div class="aspect-[4/3] overflow-hidden rounded-2xl shadow-xl">
                <img
                  src={service.image.url.startsWith('http') ? service.image.url : `${STRAPI_URL}${service.image.url}`}
                  alt={service.title}
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <CallToAction />
</Base>
