---
import Base from "@/layouts/Base.astro";
import { getResourceLibraries, STRAPI_URL } from "@/lib/utils/strapiApi";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import { markdownify } from "@/lib/utils/textConverter";

export async function getStaticPaths() {
  const resources = await getResourceLibraries();
  return generatePaths().flatMap(({ params: { lang } }) =>
    resources.map(r => ({ params: { lang, slug: r.slug } }))
  );
}


// Get slug from params
const { slug } = Astro.params;

// Fetch all resources and find the one with matching slug
const allResources = await getResourceLibraries();
const resource = allResources.find(r => r.slug === slug);

// If not found, redirect to 404
if (!resource) {
  return Astro.redirect('/404');
}
// NOTE: we deliberately do **not** redirect when the type isn't article;
// the page will render an appropriate viewer per type below.

// Mock page data
const indexData = {
  title: resource.title,
  // category is optional and may not be recognized by TS here
  subtitle: (resource as any).category || '',
  metaDescription: resource.title,
  draft: false
};

// Helper function to extract YouTube video ID
function getYouTubeVideoId(url: string): string {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length == 11) ? match[2] : '';
}
---

<Base title={indexData.title} metaDescription={indexData.metaDescription} draft={indexData.draft}>
  <PageHeader {...indexData} />

  <!-- Article Content Section -->
  <section class="py-16 md:py-20 lg:py-24 bg-theme-light">
    <div class="container max-w-4xl">
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100">
        <!-- Media preview/header for non-video types -->
        {resource.resourceType === 'video' && resource.videoUrl ? (
          <div class="aspect-video overflow-hidden">
            {resource.videoUrl.includes('youtube.com') || resource.videoUrl.includes('youtu.be') ? (
              <iframe
                src={`https://www.youtube.com/embed/${getYouTubeVideoId(resource.videoUrl)}`}
                title={resource.title}
                class="w-full h-full rounded-t-2xl"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            ) : (
              <video
                src={resource.videoUrl.startsWith('http') ? resource.videoUrl : `${STRAPI_URL}${resource.videoUrl}`}
                controls
                class="w-full h-full rounded-t-2xl"
              ></video>
            )}
          </div>
        ) : resource.resourceType === 'audio' && resource.media && resource.media.url ? (
          <div class="aspect-[16/9] overflow-hidden bg-gray-100">
            {resource.coverArt && resource.coverArt.url ? (
              <img
                src={resource.coverArt.url.startsWith('http') ? resource.coverArt.url : `${STRAPI_URL}${resource.coverArt.url}`}
                alt={resource.title}
                class="w-full h-full object-cover"
              />
            ) : resource.image ? (
              <img
                src={resource.image.url.startsWith('http') ? resource.image.url : `${STRAPI_URL}${resource.image.url}`}
                alt={resource.title}
                class="w-full h-full object-cover"
              />
            ) : null}
            <div class="p-6">
              <audio controls class="w-full">
                <source src={resource.media.url.startsWith('http') ? resource.media.url : `${STRAPI_URL}${resource.media.url}`} type={resource.media.mime} />
                Your browser does not support the audio element.
              </audio>
            </div>
          </div>
        ) : resource.resourceType === 'image' && resource.media && resource.media.url ? (
          <div class="aspect-[16/9] overflow-hidden">
            <a
              href={resource.media.url.startsWith('http') ? resource.media.url : `${STRAPI_URL}${resource.media.url}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <img
                src={resource.media.url.startsWith('http') ? resource.media.url : `${STRAPI_URL}${resource.media.url}`}
                alt={resource.title}
                class="w-full h-full object-cover"
              />
            </a>
          </div>
        ) : resource.resourceType === 'pdf' && (resource.pdfUrl || resource.externalUrl || resource.media) ? (
          <div class="aspect-[16/9] overflow-hidden">
            <iframe
              src={
                resource.pdfUrl || resource.externalUrl ||
                (resource.media ? (resource.media.url.startsWith('http') ? resource.media.url : `${STRAPI_URL}${resource.media.url}`) : '')
              }
              class="w-full h-full"
            ></iframe>
          </div>
        ) : null}

        <!-- Article Header -->
        <div class="p-6 md:p-8 lg:p-12">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center space-x-4">
              <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${
                resource.resourceType === 'video' ? 'bg-red-100 text-red-800' :
                resource.resourceType === 'pdf' ? 'bg-blue-100 text-blue-800' :
                resource.resourceType === 'document' ? 'bg-green-100 text-green-800' :
                resource.resourceType === 'article' ? 'bg-purple-100 text-purple-800' :
                'bg-gray-100 text-gray-800'
              }`}>
                {resource.resourceType === 'video' && (
                  <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
                  </svg>
                )}
                {resource.resourceType === 'pdf' && (
                  <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
                  </svg>
                )}
                {resource.resourceType === 'document' && (
                  <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/>
                  </svg>
                )}
                {resource.resourceType === 'article' && (
                  <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 002 2H4a2 2 0 01-2-2V5zm3 1h6v4H5V6zm6 6H5v2h6v-2z" clip-rule="evenodd"/>
                  </svg>
                )}
                {resource.resourceType || 'other'}
              </span>
              {resource.featured && (
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
                  Featured
                </span>
              )}
            </div>
          {resource.publishedAt && (
            <time class="text-sm text-gray-500" datetime={resource.publishedAt}>
              {new Date(resource.publishedAt).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          )}
          </div>

          <h1 class="text-3xl md:text-4xl lg:text-5xl text-primary mb-6 leading-tight">{resource.title}</h1>

          <!-- Article Content -->
          {resource.content && (
            <div class="prose prose-lg max-w-none">
              {markdownify(resource.content)}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Base>