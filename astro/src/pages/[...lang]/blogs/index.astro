---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import BlogListPage from "@/components/BlogListPage.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import CallToAction from "@/components/sections/CallToAction.astro";

export function getStaticPaths() {
  return generatePaths();
}
---

<Base title="Insights & Updates" fitToScreen={false}>
  <PageHeader title="Insights & Updates" subtitle="Stay updated with our latest insights and industry updates" />
  <BlogListPage />
  <CallToAction />
</Base>
