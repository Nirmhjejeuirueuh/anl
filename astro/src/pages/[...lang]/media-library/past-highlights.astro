---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import ImageModal from "@/components/utilities/ImageModal.astro";
import MediaMarqueeSections from "@/components/media/MediaMarqueeSections.astro";
import { getMediaLibrary } from "@/lib/utils/strapiApi";
import type { StrapiMediaSection } from "@/lib/utils/strapiApi";

export function getStaticPaths() {
  return generatePaths();
}

const mediaLibrary = await getMediaLibrary();
const allSections: StrapiMediaSection[] = mediaLibrary?.sections || [];
const pastHighlightsSections = allSections.filter(
  (section: StrapiMediaSection) => section.stage === 'pastHighlights' || !section.stage
);
---

<Base title="Past Highlights" fitToScreen={false}>
  <PageHeader
    title="Past Highlights"
    subtitle="Explore our collection of past media highlights and memorable moments"
  />

  <!-- Back to Media Library -->
  <section class="py-4 bg-theme-light border-b border-gray-100">
    <div class="container">
      <a
        href={`/${['en', 'fr'].includes(Astro.params.lang ?? '') ? Astro.params.lang : ''}/media-library`.replace(/^\/\//,  '/')}
        class="inline-flex items-center text-primary font-medium hover:text-primary/80 transition-colors"
      >
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Media Library
      </a>
    </div>
  </section>

  {pastHighlightsSections.length > 0 ? (
    <MediaMarqueeSections sections={pastHighlightsSections} showBadge={true} />
  ) : (
    <section class="py-16 md:py-20 lg:py-24 bg-gray-50">
      <div class="container text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">No Past Highlights Yet</h2>
        <p class="text-gray-600">Check back later for our collection of past media highlights.</p>
      </div>
    </section>
  )}

  <CallToAction />
  <ImageModal />
</Base>
