---
import Base from "@/layouts/Base.astro";
import { generatePaths } from "@/lib/utils/i18nUtils.ts";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import ImageModal from "@/components/utilities/ImageModal.astro";
import MediaMarqueeSections from "@/components/media/MediaMarqueeSections.astro";
import { getMediaLibrary } from "@/lib/utils/strapiApi";
import type { StrapiMediaSection } from "@/lib/utils/strapiApi";

export function getStaticPaths() {
  return generatePaths();
}

const mediaLibrary = await getMediaLibrary();
const activeSections = (mediaLibrary?.sections || []).filter((s: StrapiMediaSection) => s.stage === 'active');
const pastHighlightsSections = (mediaLibrary?.sections || []).filter((s: StrapiMediaSection) => s.stage === 'pastHighlights' || !s.stage);
---

<Base title={mediaLibrary?.title || "Media Library"} fitToScreen={false}>
  <PageHeader
    title={mediaLibrary?.title || "Media Library"}
    subtitle="Explore our collection of media resources"
  />

  {activeSections && activeSections.length > 0 ? (
    <>
      <!-- Sections Ribbon -->
      <section class="sections-ribbon py-6 bg-theme-light border-y border-gray-100">
        <div class="container">
          <div class="flex items-center justify-between gap-4">
            {/* Active Sections - Left Side */}
            <div class={`flex items-center gap-4 overflow-x-auto pb-2 flex-nowrap px-4 ${activeSections.length <= 4 ? 'justify-start' : ''}`}>
              {activeSections.map((section: StrapiMediaSection, index: number) => {
                return (
                  <a
                    href={`#section-anchor-${section.id}`}
                    data-smooth-scroll
                    class="ribbon-link inline-flex items-center px-4 py-2 font-medium rounded-full transition-colors whitespace-nowrap cursor-pointer bg-primary/5 hover:bg-primary/10 text-primary border border-primary/20 hover:border-primary/40"
                    data-aos="fade-up-sm"
                    data-aos-delay={index * 50}
                  >
                    {section.title}
                    <svg class="ml-2 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                );
              })}
            </div>

            {/* Past Highlights Link - Right Side */}
            {pastHighlightsSections && pastHighlightsSections.length > 0 && (
              <div class="flex items-center gap-4 overflow-x-auto pb-2 flex-nowrap px-4">
                <a
                  href={`/${['en', 'fr'].includes(Astro.params.lang ?? '') ? Astro.params.lang : ''}/media-library/past-highlights`.replace(/^\/\//, '/')}
                  class="inline-flex items-center px-4 py-2 font-medium rounded-full transition-colors whitespace-nowrap cursor-pointer bg-gray-100 hover:bg-gray-200 text-gray-700 border border-gray-300 hover:border-gray-400"
                  data-aos="fade-up-sm"
                  data-aos-delay={activeSections.length * 50}
                >
                  <svg class="mr-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Past Highlights
                  <svg class="ml-2 w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </section>

      <MediaMarqueeSections sections={activeSections} />
    </>
  ) : (
    <section class="py-16 md:py-20 lg:py-24 bg-gray-50">
      <div class="container">
        <div class="text-center">
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Media Library Coming Soon</h2>
          <p class="text-gray-600">We're working on organizing our media collection. Check back soon!</p>
        </div>
      </div>
    </section>
  )}

  <CallToAction/>
  <ImageModal />

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('a[data-smooth-scroll]').forEach(link => {
        link.addEventListener('click', function (e) {
          e.preventDefault();
          const anchor = e.currentTarget as HTMLAnchorElement;
          const targetId = anchor.getAttribute('href')?.slice(1);
          const target = targetId ? document.getElementById(targetId) : null;
          if (!target) return;
          const ribbon = document.querySelector('.sections-ribbon');
          const offset = ribbon ? ribbon.getBoundingClientRect().height + 16 : 80;
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        });
      });
    });
  </script>
</Base>